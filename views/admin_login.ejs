<!DOCTYPE html>
<html lang="tr">
<head>
    <script src="https://cdn.tailwindcss.com"></script>
    <title>OFO Admin Giriş</title>
</head>
<body class="bg-[#050505] flex items-center justify-center h-screen">
    <form action="/admin-login-check" method="POST" class="bg-[#0a0a0a] p-12 rounded-2xl border border-[#D4AF37]/20 w-96">
        <h2 class="text-[#D4AF37] text-2xl font-bold mb-8 text-center tracking-widest">OFO PANEL</h2>
        <input type="password" name="password" placeholder="Şifre" class="w-full bg-white/5 border-b border-white/10 py-3 px-4 outline-none focus:border-[#D4AF37] text-white text-center mb-6" required>
        <button type="submit" class="w-full bg-[#D4AF37] text-black font-bold py-4 uppercase hover:bg-white transition duration-500">GİRİŞ YAP</button>
        <% if(locals.error) { %> <p class="text-red-500 text-xs text-center mt-4"><%= error %></p> <% } %>
    </form>
</body>
</html>