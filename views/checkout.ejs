<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OFO HOTEL | Rezervasyon Onayı</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root { --gold: #D4AF37; --dark: #050505; --soft-dark: #0c0c0c; }
        body { background-color: var(--dark); color: #fff; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .serif { font-family: 'Cinzel', serif; }
        .gold { color: var(--gold); }
        .bg-gold { background-color: var(--gold); }
        .border-gold { border-color: rgba(212, 175, 55, 0.2); }
        
        /* Premium Input Styles */
        input, select { 
            background: rgba(255, 255, 255, 0.03) !important; 
            border: 1px solid rgba(255, 255, 255, 0.05) !important;
            transition: all 0.4s ease;
        }
        input:focus { 
            border-color: var(--gold) !important; 
            background: rgba(212, 175, 55, 0.05) !important;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.1);
        }
        
        /* Glassmorphism */
        .glass-card { 
            background: rgba(12, 12, 12, 0.8); 
            backdrop-filter: blur(20px); 
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .step-line { width: 2px; height: 40px; background: linear-gradient(to bottom, var(--gold), transparent); }
        
        @keyframes slideIn { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
        .animate-slide { animation: slideIn 0.8s ease forwards; }

        /* Card Preview */
        .credit-card {
            background: linear-gradient(135deg, #1a1a1a 0%, #050505 100%);
            border: 1px solid rgba(212, 175, 55, 0.3);
            aspect-ratio: 1.6/1;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">

    <header class="p-8 border-b border-white/5 flex justify-between items-center px-12 md:px-24">
        <a href="/" class="text-xl serif italic tracking-[0.3em] gold">OFO <span class="text-white">HOTEL</span></a>
        <div class="flex items-center space-x-4 opacity-40 text-[10px] uppercase tracking-widest font-bold">
            <i data-lucide="shield-check" class="w-4 gold"></i>
            <span>Güvenli Rezervasyon Sistemi</span>
        </div>
    </header>

    <main class="flex-1 max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-12 gap-12 py-16 px-6 md:px-12">
        
        <div class="lg:col-span-5 space-y-8 animate-slide">
            <h2 class="text-3xl serif italic mb-8">Rezervasyon <span class="gold text-4xl">Detayları</span></h2>
            
            <div class="glass-card rounded-3xl overflow-hidden p-2 border-gold">
                <img src="<%= oda.image || 'https://images.unsplash.com/photo-1618773928121-c32242e63f39?q=80&w=800' %>" 
                     class="w-full h-64 object-cover rounded-2xl mb-8" alt="Oda">
                
                <div class="p-6 space-y-6">
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-2xl serif gold italic mb-2 uppercase tracking-widest"><%= oda.title %></h3>
                            <p class="text-[10px] opacity-40 uppercase tracking-[0.3em] italic"><%= oda.view %> Manzaralı Modül</p>
                        </div>
                        <div class="text-right">
                            <span class="text-2xl font-bold">₺<%= oda.price %></span>
                            <p class="text-[9px] opacity-30 uppercase tracking-widest mt-1">Gecelik / KDV Dahil</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4 border-y border-white/5 py-6">
                        <div class="flex items-center space-x-3">
                            <i data-lucide="calendar" class="w-4 gold opacity-50"></i>
                            <div class="text-[10px] uppercase tracking-widest">
                                <span class="block opacity-30">Giriş</span>
                                <span class="font-bold">04 Mart 2026</span>
                            </div>
                        </div>
                        <div class="flex items-center space-x-3">
                            <i data-lucide="clock" class="w-4 gold opacity-50"></i>
                            <div class="text-[10px] uppercase tracking-widest">
                                <span class="block opacity-30">Check-in</span>
                                <span class="font-bold">14:00'den itibaren</span>
                            </div>
                        </div>
                    </div>

                    <ul class="space-y-3">
                        <li class="flex items-center text-[10px] uppercase tracking-widest opacity-60">
                            <i data-lucide="check-circle" class="w-3 mr-3 gold"></i> Ücretsiz İptal Seçeneği
                        </li>
                        <li class="flex items-center text-[10px] uppercase tracking-widest opacity-60">
                            <i data-lucide="check-circle" class="w-3 mr-3 gold"></i> Sabah Kahvaltısı Dahil
                        </li>
                        <li class="flex items-center text-[10px] uppercase tracking-widest opacity-60">
                            <i data-lucide="check-circle" class="w-3 mr-3 gold"></i> VIP Havaalanı Transferi
                        </li>
                    </ul>
                </div>
            </div>

            <div class="p-8 border border-white/5 rounded-2xl opacity-40 text-[9px] uppercase tracking-[0.2em] leading-loose italic">
                * Bu rezervasyon, Antalya OFO Hotels Group kalite standartları ve gizlilik politikası güvencesi altındadır.
            </div>
        </div>

        <div class="lg:col-span-7 animate-slide delay-1">
            <div class="glass-card rounded-[3rem] p-10 md:p-16 relative">
                <div class="absolute top-0 right-10 w-20 h-1 bg-gold"></div>
                
                <h4 class="text-[10px] uppercase tracking-[0.6em] gold font-bold mb-10">Ödeme Ve Bilgiler</h4>
                
                <form action="/complete-booking" method="POST" class="space-y-8">
                    <input type="hidden" name="room_id" value="<%= oda.id %>">
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[9px] uppercase tracking-widest gold font-bold">Tam İsim</label>
                            <input type="text" name="name" placeholder="John Doe" class="w-full py-4 px-6 rounded-xl text-sm" required>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[9px] uppercase tracking-widest gold font-bold">E-Posta Adresi</label>
                            <input type="email" name="email" placeholder="john@luxury.com" class="w-full py-4 px-6 rounded-xl text-sm" required>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[9px] uppercase tracking-widest gold font-bold">Telefon Numarası</label>
                        <input type="tel" name="phone" placeholder="+90 5XX XXX XX XX" class="w-full py-4 px-6 rounded-xl text-sm" required>
                    </div>

                    <div class="credit-card rounded-2xl p-8 my-10 flex flex-col justify-between shadow-2xl">
                        <div class="flex justify-between items-start">
                            <i data-lucide="contact-2" class="w-10 opacity-40"></i>
                            <span class="gold serif italic opacity-50 tracking-widest">OFO CARD</span>
                        </div>
                        <div class="space-y-4">
                            <div class="text-xl tracking-[0.3em] font-light text-white/40">•••• •••• •••• ••••</div>
                            <div class="flex justify-between items-center">
                                <span class="text-[8px] uppercase tracking-widest opacity-20">Card Holder</span>
                                <span class="text-[8px] uppercase tracking-widest opacity-20">Exp</span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <div class="space-y-2">
                            <label class="text-[9px] uppercase tracking-widest gold font-bold">Kart Üzerindeki İsim</label>
                            <input type="text" class="w-full py-4 px-6 rounded-xl text-sm uppercase" required>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-[9px] uppercase tracking-widest gold font-bold">Kart Numarası</label>
                                <input type="text" placeholder="0000 0000 0000 0000" class="w-full py-4 px-6 rounded-xl text-sm" required>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[9px] uppercase tracking-widest gold font-bold">SKT</label>
                                    <input type="text" placeholder="MM/YY" class="w-full py-4 px-6 rounded-xl text-sm" required>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[9px] uppercase tracking-widest gold font-bold">CVV</label>
                                    <input type="password" placeholder="***" class="w-full py-4 px-6 rounded-xl text-sm" required>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-gold text-black py-6 rounded-xl font-bold uppercase text-[11px] tracking-[0.5em] hover:bg-white transition-all duration-700 mt-10 shadow-xl shadow-gold/5">
                        Ödemeyi Tamamla & Onayla
                    </button>
                    
                    <p class="text-center text-[8px] opacity-30 uppercase tracking-widest flex items-center justify-center">
                        <i data-lucide="lock" class="w-3 mr-2"></i> 256-Bit SSL Şifreleme İle Korunmaktadır
                    </p>
                </form>
            </div>
        </div>
    </main>

    <footer class="py-12 text-center border-t border-white/5 opacity-20 text-[8px] uppercase tracking-[1em] italic">
        OFO HOTEL & TOWER ANTALYA | PREMIUM REZERVASYON MERKEZİ
    </footer>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>